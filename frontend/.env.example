# Example Environment Variables for LinkNest Frontend
# Copy this file to .env and update the values

# API Configuration - REQUIRED
VITE_API_BASE_URL=https://your-backend-domain.com
VITE_SOCKET_URL=https://your-backend-domain.com

# App Configuration
VITE_APP_NAME=LinkNest
VITE_APP_VERSION=1.0.0
VITE_NODE_ENV=production

# Optional: Social Media Integration
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
VITE_FACEBOOK_APP_ID=your-facebook-app-id-here

# Optional: Analytics
VITE_GA_TRACKING_ID=your-google-analytics-id-here

# Optional: Error Reporting
VITE_SENTRY_DSN=your-sentry-dsn-here

# Optional: CDN
VITE_CDN_URL=https://your-cdn-domain.com

# File Upload Configuration
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp